{
  "type": "module",
  "name": "@nexso/eslint-config-typescript",
  "version": "2.0.2",
  "description": "Nexso Flat Config for TypeScript projects using ESLint 10",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint index.js index.test.js eslint.config.js",
    "prepublishOnly": "npm test && npm run lint",
    "test": "node ./index.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nexsolab/eslint-config-typescript.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "flat-config",
    "typescript",
    "nuxt",
    "vue"
  ],
  "dependencies": {
    "typescript-eslint": "^8.64.0"
  },
  "devDependencies": {
    "@nexso/eslint-config": "file:../eslint-config",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@nexso/eslint-config": "^3.0.0",
    "eslint": "^10.7.0",
    "typescript": ">=5.0.0 <6.1.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "author": "Caio Eduardo <souza.caioeduardo@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nexsolab/eslint-config-typescript/issues"
  },
  "homepage": "https://github.com/nexsolab/eslint-config-typescript#readme"
}
